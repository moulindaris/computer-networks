/**
 * Note: The returned array must be malloced, assume caller calls free().
 */
#include <stdio.h>
#include <stdlib.h>

int* countBits(int n, int* returnSize) {
    *returnSize = n + 1;
    int* ans = (int*)malloc((*returnSize) * sizeof(int));
    if (ans == NULL) {
        return NULL; 
    }
    ans[0] = 0;
    for (int i = 1; i <= n; i++) {
        ans[i] = ans[i / 2] + (i % 2);
    }
    
    return ans;
}
